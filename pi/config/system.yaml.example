# System configuration
# Copy to system.yaml and fill in real values before deploying.

auth:
  token: "CHANGE_ME"  # required — set a unique secret token

network:
  ssid: "Pillar-Control"
  password: "CHANGE_ME"  # set your Wi-Fi hotspot password
  ip: "192.168.4.1"
  hostname: "pillar"
  mdns: "pillar.local"

ui:
  port: 80
  dev_port: 8000

display:
  target_fps: 60
  gamma: 2.2
  startup_scene: "rainbow_rotate"

brightness:
  manual_cap: 0.8
  auto_enabled: false
  location:
    lat: 37.7749
    lon: -122.4194
    timezone: "America/Los_Angeles"
  solar:
    night_brightness: 0.3
    dawn_offset_minutes: 30
    dusk_offset_minutes: 30

transport:
  baud: 115200
  reconnect_interval_ms: 1000
  handshake_timeout_ms: 3000
  frame_timeout_ms: 500
  max_upload_mb: 50

render:
  internal_width: 40
  output_width: 10
  height: 172

logging:
  level: "INFO"
  max_log_size_mb: 10
  max_log_files: 5
